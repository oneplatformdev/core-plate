# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment / secrets — keep .env.example as the only checked-in template
.env
.env.*
!.env.example

# yarn 4 (Berry) — ignore everything in .yarn except subfolders we actually
# want to commit (yarn binary, plugins, patches, sdks, versions). install-state.gz
# is a local resolver cache, regenerated on each `yarn install`.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
