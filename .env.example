# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit a populated copy.

# npm access token used by `yarn release` to publish without interactive 2FA.
# Generate at: https://www.npmjs.com/settings/<user>/tokens
# Recommended type: "Automation" (bypasses 2FA OTP for CI-style automation).
# Required scope: read & write on @oneplatformdev.
NPM_TOKEN=
