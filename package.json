{
  "name": "@oneplatformdev/plate",
  "version": "0.0.0",
  "description": "Plate v2 editor library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles.scoped.css": "./dist/styles.scoped.css",
    "./package.json": "./dist/package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prepare-dist-pkg.mjs",
    "build:ts": "tsc -p tsconfig.build.json && vite build && node scripts/prepare-dist-pkg.mjs",
    "build:watch": "vite build --watch",
    "build:types": "tsc -p tsconfig.build.json",
    "build:client-admin": "yarn build && node scripts/sync-local-package.mjs ../../oneplatform-client-admin",
    "dev:client-admin": "node scripts/watch-local-package.mjs ../../oneplatform-client-admin",
    "prepare:dist": "node scripts/prepare-dist-pkg.mjs",
    "sync:client-admin": "node scripts/sync-local-package.mjs ../../oneplatform-client-admin",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@oneplatformdev/ui": ">=0.0.1 <1",
    "@oneplatformdev/utils": ">=0.0.2 <1",
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "@oneplatformdev/ui": {
      "optional": true
    },
    "@oneplatformdev/utils": {
      "optional": true
    }
  },
