    "lowlight": "^3.3.0",
    "pdf-lib": "^1.17.1",
    "platejs": "^53.0.0",
    "radix-ui": "^1.4.3",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-lite-youtube-embed": "^3.5.1",
    "react-player": "3.3.1",
    "react-textarea-autosize": "^8.5.9",
    "react-tweet": "^3.3.0",
