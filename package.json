{
  "name": "@oneplatformdev/plate",
  "version": "0.1.0",
  "description": "Plate.js v53 rich-text editor preconfigured for OnePlatform apps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oneplatformdev/core-plate.git"
  },
  "homepage": "https://github.com/oneplatformdev/core-plate#readme",
  "bugs": {
    "url": "https://github.com/oneplatformdev/core-plate/issues"
  },
  "keywords": [
    "plate",
    "platejs",
    "editor",
    "rich-text",
    "react",
    "wysiwyg",
    "slate",
    "oneplatform"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles.scoped.css": "./dist/styles.scoped.css",
    "./package.json": "./dist/package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prepare-dist-pkg.mjs",
    "build:ts": "tsc -p tsconfig.build.json && vite build && node scripts/prepare-dist-pkg.mjs",
    "build:watch": "vite build --watch",
    "build:types": "tsc -p tsconfig.build.json",
    "prepare:dist": "node scripts/prepare-dist-pkg.mjs",
    "sync:link": "node scripts/sync-local-package.mjs",
    "dev:link": "node scripts/watch-local-package.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "yarn build:ts && node --env-file=.env scripts/release.mjs"
  },
  "peerDependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": ">=0.544.0 <2",
    "react": ">=18 <20",
    "react-day-picker": "^9.0.0",
    "react-dom": ">=18 <20",
    "tailwind-merge": "^3.0.0",
    "zod": ">=3.0.0 <5"
  },
  "peerDependenciesMeta": {
    "react-day-picker": {
      "optional": true
    }
  },
  "dependencies": {
    "@ariakit/react": "^0.4.26",
    "@emoji-mart/data": "1.2.1",
