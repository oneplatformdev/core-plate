    "@platejs/excalidraw": "^53.0.0",
    "@platejs/floating": "^53.0.0",
    "@platejs/footnote": "^53.0.0",
    "@platejs/indent": "^53.0.0",
    "@platejs/juice": "^53.0.0",
    "@platejs/layout": "^53.0.0",
